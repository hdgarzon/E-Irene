# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # solo server; tareas de sistema (audit, RPC admin)
NEXT_PUBLIC_APP_URL=                # dominio público, p.ej. https://e-irene.co (usado en links de paciente)

# ── Cifrado app-layer (AES-256-GCM) ───────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── Proveedores externos (opcionales: activan modo "live") ─
DEEPGRAM_API_KEY=                   # vacío → transcripción en modo mock
OPENAI_API_KEY=                     # vacío → análisis IA en modo mock
RESEND_API_KEY=                     # vacío → email en modo log/mock
EMAIL_FROM=                         # remitente, p.ej. "E-Irene <citas@tudominio.co>"

# ── WhatsApp (Twilio) — opcional, planes Clínica/Enterprise ─
TWILIO_ACCOUNT_SID=                 # vacío → WhatsApp en modo log/mock
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=               # p.ej. "whatsapp:+14155238886"

# ── Telehealth (Daily.co) ─────────────────────────────────
DAILY_API_KEY=                      # vacío → videollamada en modo mock
VIDEO_PROVIDER=                     # forzado opcional: mock | daily
NEXT_PUBLIC_SITE_URL=               # p.ej. https://app.tudominio.co (para links de /join)

# Forzado opcional de proveedor (mock | deepgram | openai)
TRANSCRIPTION_PROVIDER=
ANALYSIS_PROVIDER=
